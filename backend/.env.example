
# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/settle_booking

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE_TIME=7d

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:8080

# Encryption key for storing Google tokens
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Email (Brevo)
# Required for all transactional emails
BREVO_API_KEY=__REPLACE_ME__

# Default mail settings
MAIL_FROM=tech@settle.com
MAIL_FROM_NAME=Settle
MAIL_FEEDBACK_TO=tech@settle.com
# Optional: tag prefix to group email metrics
MAIL_TAG_PREFIX=settle

# (Optional) SMTP fallback (if you configure your own SMTP provider)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=__REPLACE_ME__
# SMTP_PASSWORD=__REPLACE_ME__
# SMTP_FROM_EMAIL=__REPLACE_ME__
