{
  "name": "settle-calendar-backend",
  "version": "1.0.0",
  "description": "Backend API for Settle booking application with Google Calendar integration",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && cp src/swagger.js dist/ 2>/dev/null || true",
    "migrate": "node dist/scripts/migrate.js",
    "prestart": "node dist/scripts/migrate.js",
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
    "watch": "tsc -w",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.json"
      }
    },
    "testTimeout": 15000
  },
  "keywords": [
    "booking",
    "calendar",
    "google-calendar",
    "api"
  ],
  "author": "Settle",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^8.0.0",
    "@types/nodemailer": "^6.4.17",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "googleapis": "^133.0.0",
    "helmet": "^7.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "nodemailer": "^7.0.5",
    "pg": "^8.11.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^29.5.12",
    "@types/joi": "^17.2.2",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.1",
    "@types/pg": "^8.15.4",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.5",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2"
  }
}
